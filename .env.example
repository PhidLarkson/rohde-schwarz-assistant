# API Keys for Rhoda — R&S Virtual Lab Assistant
# Get your keys from:
# Gemini: https://aistudio.google.com
# GhanaNLP: https://ghananlp.org

VITE_GEMINI_API_KEY=your_gemini_key_here
VITE_GHANANLP_API_KEY=your_ghananlp_key_here

# Oscilloscope connection (optional — omit for simulator mode)
# SCOPE_RESOURCE=USB                                    # Auto-discover USB instrument
# SCOPE_RESOURCE=USB0::0x0AAD::0x01D6::102345::INSTR   # Specific USB VISA address
# SCOPE_RESOURCE=TCPIP::192.168.1.100::INSTR           # LAN connection
